{
  "babelrcRoots": ["*"],
    "presets": ["@babel/preset-env", "@babel/preset-typescript",
        [
           "@nrwl/react/babel",
           {
             "runtime": "automatic"
           }
         ]
       ],
    "assumptions": {
        "setPublicClassFields": true,
        "privateFieldsAsProperties": true
  },
  "plugins": [
    ["@babel/plugin-proposal-private-property-in-object", { "loose": true }]
  ]
}
