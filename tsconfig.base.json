{
    "compileOnSave": false,
    "compilerOptions": {
        "jsx": "react",
        "rootDir": ".",
        "sourceMap": true,
        "declaration": false,
        "moduleResolution": "node",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "importHelpers": true,
        "target": "ES2022",
        "module": "ES2022",
        "lib": ["ES2022", "dom"],
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@cashflowweb/common-ui": ["libs/common-ui/src/index.ts"],
            "@cashflowweb/features": ["libs/features/src/index.ts"],
            "@cashflowweb/shared/util/ts": ["libs/shared/util/ts/src/index.ts"]
        }
    },
    "exclude": ["node_modules", "tmp"]
}
